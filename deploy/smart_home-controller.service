[Unit]
Description=smart_home PV curtailment controller
After=network-online.target
Wants=network-online.target
# wlan0 -> inverter AP can take a moment after boot
StartLimitIntervalSec=0

[Service]
Type=simple
User=solarpi
WorkingDirectory=/home/solarpi/smart_home
EnvironmentFile=/etc/smart_home.env
ExecStart=/home/solarpi/smart_home/.venv/bin/python -m smart_home.controller --p1-host ${P1_HOST}
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
