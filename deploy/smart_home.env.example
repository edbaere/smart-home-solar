# /etc/smart_home.env  — secrets + config for the systemd units.
# Install: sudo cp this file to /etc/smart_home.env, fill in values, then
#   sudo chown root:root /etc/smart_home.env && sudo chmod 600 /etc/smart_home.env

# ENTSO-E Transparency Platform Web API token (for the daily price fetch)
ENTSOE_API_TOKEN=your-entsoe-token

# Inverter installer login (for curtailment writes). User is normally "installer".
HUAWEI_USER=installer
HUAWEI_PW=your-installer-password

# HomeWizard P1 meter host (IoT network)
P1_HOST=192.168.3.74
